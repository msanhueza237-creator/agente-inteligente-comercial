# Copiar a .env y completar con valores reales. Nunca commitear .env.

ENV=development

# Database (Supabase Postgres)
# Runtime: usar el connection string agrupado por Supavisor (puerto 6543)
DATABASE_URL=postgresql+asyncpg://postgres:password@host:6543/postgres
# Migraciones (Alembic): usar la conexion directa (puerto 5432)
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:password@host:5432/postgres

# Google Maps Places API
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_DAILY_BUDGET_USD=20.0
GOOGLE_PLACES_MONTHLY_BUDGET_USD=400.0

# Brave Search API (fuente web general autorizada)
BRAVE_SEARCH_API_KEY=

# Compatibilidad: Amarillas permanece bloqueado en codigo hasta implementar
# un feed/API oficial autorizado. Estos flags no habilitan scraping HTML.
PAGINAS_AMARILLAS_ENABLED=false
PAGINAS_AMARILLAS_LICENSE_CONFIRMED=false

# CRM. En producción CRM_MODE=http es obligatorio. La llave debe tener sólo el
# scope prospecting:execute y nunca debe copiarse al frontend.
CRM_MODE=fake
CRM_BASE_URL=https://supabase.latinchile.cl/functions/v1/crm-agent
CRM_API_KEY=
CRM_WORKER_ID=climactiva-worker-01
CRM_TIMEOUT_SECONDS=15

# Dashboard auth
SESSION_SECRET_KEY=change-me-in-production

# Dedup / scheduler tuning
DEDUP_FUZZY_AUTO_MERGE_THRESHOLD=90.0
DEDUP_FUZZY_REVIEW_THRESHOLD=75.0
REGION_CATEGORY_RECHECK_DAYS=30
WORKER_POLL_SECONDS=15
WORKER_LEASE_SECONDS=120
WORKER_HEARTBEAT_SECONDS=30
WORKER_TASK_MAX_ATTEMPTS=3
WEBSITE_MAX_BYTES=1500000
WEBSITE_TIMEOUT_SECONDS=10
